{
  "expo": {
    "name": "The Word الكلمة",
    "slug": "kalimat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "kalimat",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1248"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kalimat.app",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1248"
      },
      "package": "com.kalimat.app",
      "edgeToEdgeEnabled": true,
      "useNextNotificationsApi": true,
      "jsEngine": "hermes"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#7C3AED"
        }
      ],
      [
        "expo-navigation-bar",
        {
          "position": "absolute",
          "visibility": "hidden",
          "backgroundColor": "#0D1248"
        }
      ],
      "expo-web-browser",
      "@sentry/react-native/expo",
      "@sentry/react-native",
      "@react-native-google-signin/google-signin",
      "expo-apple-authentication"
    ],
    "extra": {
      "router": {},
      "expo-navigation-bar": {
        "position": "absolute",
        "visibility": "hidden",
        "backgroundColor": "#0D1248"
      },
      "eas": {
        "projectId": "6d33de9e-032f-4eb4-9960-b1861f37c31f"
      }
    }
  }
}
